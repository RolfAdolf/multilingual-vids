# HTTP API: /api/v1/videos, постановка задач в RabbitMQ (Docker)
DJANGO_SECRET_KEY=change-me-in-production
DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1,worker-api
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:5173
CORE_SRC_PATH=/app/core-api/src

DATABASE_URL=postgres://mv:mv@postgres:5432/multilingual_videos
CELERY_BROKER_URL=amqp://guest:guest@rabbitmq:5672//
CELERY_RESULT_BACKEND=django-db
REDIS_URL=redis://redis:6379/0

GUNICORN_WORKERS=2
