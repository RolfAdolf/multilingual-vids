# Очередь seamless (SeamlessM4T)
CELERY_QUEUE=seamless
# false — не грузить модель при старте; задачи из очереди → ERROR в БД
WORKER_ENABLED=true

# Hugging Face SeamlessM4T (speech-to-speech)
SEAMLESS_HF_MODEL_ID=facebook/seamless-m4t-v2-large
# Path inside the container. docker-compose mounts the host model dir here.
SEAMLESS_MODEL_LOCAL_DIR=/models/seamless-m4t-v2-large
# Production (GPU): cuda | Local dev overlay forces cpu
SEAMLESS_DEVICE=cuda
# 0 (default) = model maximum (4096). Lower only to save VRAM/time.
# SEAMLESS_MAX_NEW_TOKENS=4096
