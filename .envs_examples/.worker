# Celery workers — значения по умолчанию для Docker Compose.
# Локально: .envs/.db и .envs/.broker переопределяют DATABASE_URL и CELERY_* на localhost.
DJANGO_SECRET_KEY=change-me-in-production
DEBUG=true
CORE_SRC_PATH=/app/core-api/src

DATABASE_URL=postgres://mv:mv@postgres:5432/multilingual_videos
CELERY_BROKER_URL=amqp://guest:guest@rabbitmq:5672//
CELERY_RESULT_BACKEND=django-db
REDIS_URL=redis://redis:6379/0

CELERY_LOGLEVEL=info
CELERY_CONCURRENCY=1
