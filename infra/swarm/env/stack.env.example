# Copy to infra/swarm/env/stack.env and adjust before swarm deploy.
# Loaded by scripts/swarm-deploy.sh together with .envs/.deploy

# Image registry prefix (trailing slash optional). Empty = local tags only.
# Example: registry.example.com/mv/
IMAGE_PREFIX=multilingual-vids/
IMAGE_TAG=latest

# Published HTTP port (host mode on edge node)
HTTP_PORT=80

# SeamlessM4T on GPU node (bind mount, read-only)
SEAMLESS_HOST_MODEL_DIR=/opt/models/seamless-m4t-v2-large

# Swarm stack name
STACK_NAME=multilingual-vids

# Service scale (stateless only)
CORE_API_REPLICAS=1
FRONTEND_REPLICAS=1

# Django (override .envs/.core-api if needed)
ALLOWED_HOSTS=localhost,127.0.0.1,your.domain
CORS_ALLOWED_ORIGINS=http://localhost,https://your.domain
